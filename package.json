{
  "name": "model-forge-viewer-2",
  "version": "2.0.0-alpha.4",
  "description": "Desktop 3D model viewer and converter for 3D printing (STL, OBJ, 3MF, STEP) — v2 rewrite",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack:win": "npm run icons && npm run build && node scripts/pack-win.cjs",
    "pack:win:setup": "npm run icons && npm run build && node scripts/pack-win.cjs -- --win nsis",
    "pack:mac": "npm run icons && npm run build && electron-builder --mac --publish never",
    "icons": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "fast-xml-parser": "^5.8.0",
    "jszip": "^3.10.1",
    "occt-import-js": "^0.0.23",
    "postprocessing": "^6.39.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^8.0.14"
  },
  "build": {
    "appId": "com.modelforge.viewer",
    "productName": "Model Forge",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "icon.png",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "out/renderer/**/*.wasm"
    ],
    "afterPack": "./scripts/after-pack-rcedit.cjs",
    "extraFiles": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "fileAssociations": [
      {
        "ext": "stl",
        "name": "ModelForge.stl",
        "description": "Stereolithography / 3D print mesh",
        "icon": "icon.ico"
      },
      {
        "ext": "obj",
        "name": "ModelForge.obj",
        "description": "Wavefront OBJ model",
        "icon": "icon.ico"
      },
      {
        "ext": "3mf",
        "name": "ModelForge.3mf",
        "description": "3D Manufacturing Format",
        "icon": "icon.ico"
      },
      {
        "ext": "step",
        "name": "ModelForge.step",
        "description": "ISO STEP CAD",
        "icon": "icon.ico"
      },
      {
        "ext": "stp",
        "name": "ModelForge.stp",
        "description": "ISO STEP CAD",
        "icon": "icon.ico"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "shortcutName": "Model Forge",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "perMachine": true,
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "identity": null,
      "notarize": false,
      "extraFiles": [],
      "extraResources": [
        {
          "from": "build/icon.png",
          "to": "icon.png"
        }
      ],
      "fileAssociations": [
        { "ext": "stl",  "name": "STL 3D model",  "role": "Viewer" },
        { "ext": "obj",  "name": "OBJ 3D model",  "role": "Viewer" },
        { "ext": "3mf",  "name": "3MF 3D model",  "role": "Viewer" },
        { "ext": "step", "name": "STEP CAD file", "role": "Viewer" },
        { "ext": "stp",  "name": "STEP CAD file", "role": "Viewer" }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac.${ext}"
    }
  }
}
